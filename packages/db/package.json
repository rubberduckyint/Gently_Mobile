{
  "name": "@gently/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./src/schema.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "push": "pnpm with-env drizzle-kit push",
    "studio": "pnpm with-env drizzle-kit studio",
    "seed": "pnpm with-env tsx src/seed.ts",
    "seed:quick": "pnpm with-env tsx src/seed-quick.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@vercel/postgres": "^0.10.0",
    "drizzle-cuid2": "^2.1.0",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "minimatch": "^10.0.3",
    "postgres": "^3.4.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@gently/eslint-config": "workspace:*",
    "@gently/prettier-config": "workspace:*",
    "@gently/tsconfig": "workspace:*",
    "@types/pg": "^8.15.5",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "^4.20.5",
    "typescript": "catalog:"
  },
  "prettier": "@gently/prettier-config"
}
